# Vet-AI — environment template (start here)
# Related: .env.local (gitignored dev), .env.training (ML hyperparams), .env.production (Docker DNS reference)
# See README "Environment files in this repository".
#
# Docker Compose in vet-microservices typically loads ../vet-infra/.env for the vet-ai container.
# Copy this file to .env.local (gitignored) or merge into vet-infra/.env.
#
# Prometheus metrics are exposed on the same port as the API: GET http://localhost:8000/metrics
# (no separate METRICS_PORT in code).

# =============================================================================
# Option A — run on host (uvicorn) with Postgres / MLflow on localhost
# =============================================================================
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Required for continuous training, feedback, prediction logs (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/mlflow

# Admin API: Authorization: Bearer <ADMIN_TOKEN>
ADMIN_TOKEN=change-me-use-long-random-string

# Model artifacts (defaults work inside Docker image)
MODEL_DIR=./ai_service/models/v2
MODEL_ROOT_DIR=./ai_service/models

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=vet-ai-continuous-training
MLFLOW_TIMEOUT_SECONDS=10

# Training policy (continuous_training)
TRAINING_THRESHOLD=10
TRAINING_WINDOW_DAYS=30

# MLOps UI / clinic list: customers-service base URL (Spring)
CUSTOMERS_SERVICE_BASE_URL=http://localhost:8081
# CUSTOMERS_CLINICS_CACHE_TTL_SECONDS=60

# Optional: golden-set regression gate (see training_engine)
# BASELINE_DATASET_CSV=/app/baseline/veterinary_full_data_10000.csv
# BASELINE_LABEL_COL=target_diagnosis

# =============================================================================
# Option B — same keys using Docker Compose service DNS (petclinic-net)
# =============================================================================
# DATABASE_URL=postgresql://mlflow:mlflow@postgres:5432/mlflow
# MLFLOW_TRACKING_URI=http://mlflow:5000
# CUSTOMERS_SERVICE_BASE_URL=http://customers-service:8081

# =============================================================================
# Optional — EKS hybrid training (advanced; see continuous_training.py)
# =============================================================================
# ALLOW_EKS_HYBRID_TRAINING=false
# EKS_CLUSTER_NAME=vet-ai-dev
# EKS_REGION=us-east-1
# TRAINING_NODE_GROUP=training-nodes

# =============================================================================
# Not implemented as env-driven in Python (reserved / documentation only)
# =============================================================================
# ENABLE_SHAP / ENABLE_EXPLAINABILITY / API_KEY_REQUIRED / WORKERS — not read by current codebase.
# Use uvicorn CLI for workers: uvicorn ... --workers 4
