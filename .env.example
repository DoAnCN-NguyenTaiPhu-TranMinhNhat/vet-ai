# =============================================================================
# vet-ai — local / IDE (this file). Docker Compose: use ../vet-microservices/.env
# =============================================================================
# Copy:  cp .env.example .env
# Load:  set -a && source .env && set +a
# Canonical stack keys: ../vet-microservices/.env.example (sections 2–4).

# =============================================================================
# Core
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/vet_ai
ADMIN_TOKEN=
API_BASE_URL=http://localhost:8000
MODEL_VERSION=v2.0
MODEL_DIR=./ai_service/models/v2.0
MODEL_ROOT_DIR=./ai_service/models
VETAI_MODELS_ROOT=./ai_service/models
VETAI_STATE_DIR=./ai_service/state

# =============================================================================
# MLflow
# =============================================================================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=vet-ai-continuous-training
MLFLOW_TIMEOUT_SECONDS=10

# =============================================================================
# Customers (clinic catalog — clinic_catalog_service)
# =============================================================================
CUSTOMERS_SERVICE_BASE_URL=
CUSTOMERS_CLINICS_PATH=/clinics
CUSTOMERS_SERVICE_TIMEOUT_SECONDS=5
CUSTOMERS_CLINICS_CACHE_TTL_SECONDS=60

# =============================================================================
# MLAir client (optional). Compose: MLAIR_API_BASE_URL=http://mlair-api:8080
# =============================================================================
MLAIR_API_BASE_URL=
MLAIR_API_TOKEN=
MLAIR_TENANT_ID=default
MLAIR_PROJECT_GLOBAL=default_project
MLAIR_PROJECT_CLINIC_PREFIX=clinic_
MLAIR_MODEL_NAME_GLOBAL=vetai-diagnosis-global
MLAIR_MODEL_NAME_CLINIC_PREFIX=vetai-diagnosis-clinic
MLAIR_IMPORT_STAGE=staging
# Import model.pkl từ disk lên MLAir khi registry sync nếu model logical chưa có version (mặc định bật)
MLAIR_DISK_MODEL_IMPORT_AT_REGISTRY=1
# Clinic chưa có thư mục models/clinics/... thì vẫn import bản global từ disk vào model MLAir của clinic
# MLAIR_DISK_IMPORT_CLINIC_FALLBACK_GLOBAL=0
MLAIR_TIMEOUT_SECONDS=120
MLAIR_REGISTRY_SYNC_AT_STARTUP=1
MLAIR_REGISTRY_BUST_CLINIC_CACHE=1
MLAIR_REGISTRY_BOOTSTRAP_MAX_WAIT_SECONDS=120
MLAIR_REGISTRY_BOOTSTRAP_INTERVAL_SECONDS=5
MLAIR_REGISTRY_RESYNC_SECONDS=120
# MLAIR_SEED_DEMO_EXECUTOR=1
# Tắt auto-run pipeline demo (fail_once_demo…) khi chỉ cần train thật trên Vet-AI: MLAIR_SEED_DEMO_EXECUTOR_RUN=0
# MLAIR_SEED_DEMO_EXECUTOR_RUN=1
# MLAIR_SEED_PIPELINE_ID=fail_once_demo_pipeline
# MLAIR_SEED_DEMO_EXECUTOR_PROJECTS=default_project
# Override task plugins cho pipeline seed (mặc định trong code đã chuyển train plugin sang `vetai_train_invoke`).
# MLAIR_SEED_PIPELINE_CONFIG_JSON={"tasks":[{"id":"train","plugin":"vetai_train_invoke","context":{"project_id":"default_project","force":true,"training_mode":"local"}}]}
# MLAIR_REGISTRY_GLOBAL_PROJECT_NAME=Vet-AI (global)
# Ghi params/metrics/run lên MLAir sau mỗi lần train (orchestration run + tracking API)
# MLAIR_TRAINING_TRACKING=1
# MLAIR_TRACKING_PIPELINE_ID=vetai_local_training
# MLAIR_TRACKING_PLUGIN_NAME=echo_tracking
# MLAIR_TRACKING_EXPERIMENT_NAME=Vet-AI continuous training
# MLAIR_TRACKING_POLL_SECONDS=90
#
# Đồng bộ feedback bác sĩ → MLAir buffer (lineage runtime_feedback; version mới khi đủ target_threshold). Tắt: MLAIR_FEEDBACK_BUFFER_SYNC=0
MLAIR_FEEDBACK_BUFFER_SYNC=1
MLAIR_FEEDBACK_DATASET_NAME=vetai_runtime_feedback
MLAIR_FEEDBACK_TARGET_THRESHOLD=1000
MLAIR_FEEDBACK_ACCUMULATION_STRATEGY=snapshot_on_threshold
# MLAIR_FEEDBACK_SINK_PIPELINE_ID=demo_pipeline
MLAIR_FEEDBACK_SINK_PLUGIN=echo_tracking
# Bearer secret cho POST /mlops/mlair/training-invoke — gọi train PyTorch thật (giống POST /training/trigger). Để trống = tắt hook.
# MLAIR_TRAINING_INVOKE_TOKEN=

MLOPS_CLINICS_JSON=
VETAI_CHAMPION_REGISTRY_PATH=/app/models
ACCURACY_GAIN_THRESHOLD=0.01
F1_SCORE_MIN=0.85

# Optional S3 model artifact storage
VETAI_MODEL_ARTIFACT_S3_BUCKET=
VETAI_MODEL_ARTIFACT_S3_PREFIX=vet-ai/model-artifacts

# =============================================================================
# Continuous training controls
# =============================================================================
TRAINING_THRESHOLD=10
# Automatic retrain: enqueue one job per batch (watermark), not on every feedback save.
BATCH_AUTO_TRAIN_ENABLED=true
BATCH_SCOPE_COOLDOWN_MAX_SEC=900
TRAINING_WINDOW_DAYS=30
TRAINING_MIN_UNIQUE_CLASSES=2
TRAINING_CV_STRATEGY=repeated_stratified
TRAINING_CV_REPEATS=3
TRAINING_CLINIC_ID=
TRAINING_ID=unknown
TRAINING_DATA_DIR=/data
TRAINING_NODE_GROUP=training-nodes
ALLOW_EKS_HYBRID_TRAINING=false
EKS_CLUSTER_NAME=vet-ai-dev
EKS_REGION=us-east-1
DATA_SOURCE=postgres

# Promotion policy
PROMOTE_MIN_SAMPLES=20
PROMOTE_MIN_VALIDATION_F1_DELTA=0.0
PROMOTE_PRIMARY_METRIC=cv_mean_f1_weighted
PROMOTE_MIN_PRIMARY_METRIC_DELTA=0.0
PROMOTE_MAX_CV_STD_F1_WEIGHTED=999
PROMOTE_REQUIRE_BASELINE_METRIC=false

# Validation split + calibration (RoadMap B)
VALIDATION_MODE=random
TIME_AWARE_MIN_SAMPLES=30
CALIBRATION_METHOD=none
CALIBRATION_MIN_SAMPLES=50

# Fine-tuning and regression gates
FINETUNE_PREVIOUS_MODEL=true
FINETUNE_ADD_TREES=20
REGRESSION_GATE_ENABLED=true
REGRESSION_GATE_MIN_FEEDBACK_SAMPLES=20
REGRESSION_TOLERANCE_F1=0.02
REGRESSION_HIGH_BASE_F1_THRESHOLD=0.99
REGRESSION_TOLERANCE_F1_HIGH_BASE=0.25
FEEDBACK_IMPROVEMENT_GATE_ENABLED=true
FEEDBACK_GATE_TOLERANCE=0.03
METRICS_RELIABLE_MIN_SAMPLES=80
GOLDEN_TEST_MAX_ROWS=2000

# Feedback weighting
FEEDBACK_DELTA_MAX=0.25
FEEDBACK_ACCEPT_STRENGTH=0.8
FEEDBACK_REJECT_STRENGTH=0.8
FEEDBACK_POSITIVE_MAX_WEIGHT=1.5
FEEDBACK_NEGATIVE_MIN_WEIGHT=0.7

# Baseline dataset and quality thresholds
BASELINE_DATASET_CSV=
BASELINE_LABEL_COL=target_diagnosis
QUALITY_FALLBACK_THRESHOLD=0.7
QUALITY_PERCENTILE=25
QUALITY_MIN_THRESHOLD=0.5
MISSING_VALUE_THRESHOLD=0.5
MAX_UNIQUE_VALUES_FOR_CATEGORICAL=20
UNIQUE_RATIO_THRESHOLD=0.05
CLASS_COMPLETION_REFERENCE_PER_MISSING_CLASS=1
CLASS_COMPLETION_REFERENCE_QUALITY_SCORE=0.1

# Core-memory and dataset splitting
CORE_MEMORY_RATIO=0.2
CORE_MEMORY_QUALITY_SCORE=0.2
CORE_MEMORY_MAX_ROWS=5000
DEFAULT_SPLIT_RATIO=0.2
DEFAULT_CV_FOLDS=5
MAX_CV_FOLDS=5
SPLIT_RATIO_TINY=0.1
SPLIT_RATIO_SMALL=0.15
SPLIT_RATIO_MEDIUM=0.2
SPLIT_RATIO_LARGE=0.25

# Dataset size thresholds
DATASET_TINY_THRESHOLD=20
DATASET_SMALL_THRESHOLD=50
DATASET_MEDIUM_THRESHOLD=200
DATASET_LARGE_THRESHOLD=1000

# RandomForest hyperparameters
N_ESTIMATORS_SMALL=50
N_ESTIMATORS_MEDIUM=100
N_ESTIMATORS_LARGE=200
N_ESTIMATORS_XLARGE=300
MAX_DEPTH_SMALL=5
MAX_DEPTH_MEDIUM=8
MAX_DEPTH_LARGE=15
MIN_SAMPLES_SPLIT_SMALL=2
MIN_SAMPLES_SPLIT_MEDIUM=5
MIN_SAMPLES_SPLIT_LARGE=10
MIN_SAMPLES_LEAF_SMALL=1
MIN_SAMPLES_LEAF_MEDIUM=2
MIN_SAMPLES_LEAF_LARGE=4
MAX_DUMMY_FEATURES=100
RANDOM_STATE=42

# CSV bootstrap limits
CSV_BOOTSTRAP_MAX_BYTES=26214400
CSV_BOOTSTRAP_MIN_ROWS=10
CSV_BOOTSTRAP_MAX_ROWS=50000
