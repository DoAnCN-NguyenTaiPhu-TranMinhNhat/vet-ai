# =========================
# Core service configuration
# =========================
DATABASE_URL=postgresql://user:password@localhost:5432/vet_ai
ADMIN_TOKEN=admin-secret
API_BASE_URL=http://vet-ai-service:8000
MODEL_VERSION=v2.0
MODEL_DIR=./ai_service/models/v2.0
MODEL_ROOT_DIR=./ai_service/models
VETAI_MODELS_ROOT=./ai_service/models
VETAI_STATE_DIR=./ai_service/state

# =========================
# MLflow / MLOps
# =========================
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=vet-ai-continuous-training
MLFLOW_TIMEOUT_SECONDS=10
MLOPS_CLINICS_JSON=
VETAI_CHAMPION_REGISTRY_PATH=/app/models
ACCURACY_GAIN_THRESHOLD=0.01
F1_SCORE_MIN=0.85

# Optional S3 model artifact storage
VETAI_MODEL_ARTIFACT_S3_BUCKET=
VETAI_MODEL_ARTIFACT_S3_PREFIX=vet-ai/model-artifacts

# =========================
# Customers service integration
# =========================
CUSTOMERS_SERVICE_BASE_URL=
CUSTOMERS_CLINICS_PATH=/clinics
CUSTOMERS_SERVICE_TIMEOUT_SECONDS=5
CUSTOMERS_CLINICS_CACHE_TTL_SECONDS=60

# =========================
# Continuous training controls
# =========================
TRAINING_THRESHOLD=10
TRAINING_WINDOW_DAYS=30
AUTO_TRAIN_FAILURE_COOLDOWN_SECONDS=300
AUTO_TRAIN_MIN_NEW_FEEDBACK_AFTER_FAIL=5
TRAINING_MIN_UNIQUE_CLASSES=2
TRAINING_CV_STRATEGY=repeated_stratified
TRAINING_CV_REPEATS=3
TRAINING_CLINIC_ID=
TRAINING_ID=unknown
TRAINING_DATA_DIR=/data
TRAINING_NODE_GROUP=training-nodes
ALLOW_EKS_HYBRID_TRAINING=false
EKS_CLUSTER_NAME=vet-ai-dev
EKS_REGION=us-east-1
DATA_SOURCE=postgres

# Promotion policy
PROMOTE_MIN_SAMPLES=20
PROMOTE_MIN_VALIDATION_F1_DELTA=0.0
PROMOTE_PRIMARY_METRIC=cv_mean_f1_weighted
PROMOTE_MIN_PRIMARY_METRIC_DELTA=0.0
PROMOTE_MAX_CV_STD_F1_WEIGHTED=999
PROMOTE_REQUIRE_BASELINE_METRIC=false

# Validation split + calibration (RoadMap B)
VALIDATION_MODE=random
TIME_AWARE_MIN_SAMPLES=30
CALIBRATION_METHOD=none
CALIBRATION_MIN_SAMPLES=50

# Fine-tuning and regression gates
FINETUNE_PREVIOUS_MODEL=true
FINETUNE_ADD_TREES=20
REGRESSION_GATE_ENABLED=true
REGRESSION_GATE_MIN_FEEDBACK_SAMPLES=20
REGRESSION_TOLERANCE_F1=0.02
REGRESSION_HIGH_BASE_F1_THRESHOLD=0.99
REGRESSION_TOLERANCE_F1_HIGH_BASE=0.25
FEEDBACK_IMPROVEMENT_GATE_ENABLED=true
FEEDBACK_GATE_TOLERANCE=0.03
METRICS_RELIABLE_MIN_SAMPLES=80
GOLDEN_TEST_MAX_ROWS=2000

# Feedback weighting
FEEDBACK_DELTA_MAX=0.25
FEEDBACK_ACCEPT_STRENGTH=0.8
FEEDBACK_REJECT_STRENGTH=0.8
FEEDBACK_POSITIVE_MAX_WEIGHT=1.5
FEEDBACK_NEGATIVE_MIN_WEIGHT=0.7

# Baseline dataset and quality thresholds
BASELINE_DATASET_CSV=
BASELINE_LABEL_COL=target_diagnosis
QUALITY_FALLBACK_THRESHOLD=0.7
QUALITY_PERCENTILE=25
QUALITY_MIN_THRESHOLD=0.5
MISSING_VALUE_THRESHOLD=0.5
MAX_UNIQUE_VALUES_FOR_CATEGORICAL=20
UNIQUE_RATIO_THRESHOLD=0.05
CLASS_COMPLETION_REFERENCE_PER_MISSING_CLASS=1
CLASS_COMPLETION_REFERENCE_QUALITY_SCORE=0.1

# Core-memory and dataset splitting
CORE_MEMORY_RATIO=0.2
CORE_MEMORY_QUALITY_SCORE=0.2
CORE_MEMORY_MAX_ROWS=5000
DEFAULT_SPLIT_RATIO=0.2
DEFAULT_CV_FOLDS=5
MAX_CV_FOLDS=5
SPLIT_RATIO_TINY=0.1
SPLIT_RATIO_SMALL=0.15
SPLIT_RATIO_MEDIUM=0.2
SPLIT_RATIO_LARGE=0.25

# Dataset size thresholds
DATASET_TINY_THRESHOLD=20
DATASET_SMALL_THRESHOLD=50
DATASET_MEDIUM_THRESHOLD=200
DATASET_LARGE_THRESHOLD=1000

# RandomForest hyperparameters
N_ESTIMATORS_SMALL=50
N_ESTIMATORS_MEDIUM=100
N_ESTIMATORS_LARGE=200
N_ESTIMATORS_XLARGE=300
MAX_DEPTH_SMALL=5
MAX_DEPTH_MEDIUM=8
MAX_DEPTH_LARGE=15
MIN_SAMPLES_SPLIT_SMALL=2
MIN_SAMPLES_SPLIT_MEDIUM=5
MIN_SAMPLES_SPLIT_LARGE=10
MIN_SAMPLES_LEAF_SMALL=1
MIN_SAMPLES_LEAF_MEDIUM=2
MIN_SAMPLES_LEAF_LARGE=4
MAX_DUMMY_FEATURES=100
RANDOM_STATE=42

# CSV bootstrap limits
CSV_BOOTSTRAP_MAX_BYTES=26214400
CSV_BOOTSTRAP_MIN_ROWS=10
CSV_BOOTSTRAP_MAX_ROWS=50000
