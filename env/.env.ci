# CI environment defaults.
#
# vet-microservices / MLAir: CI jobs usually do not start the full compose stack. If you add integration
# tests against ml-air, mirror the same env keys as in env/.env.example (vet-microservices stack section)
# and vet-microservices/.env.local (MLAIR_*, ML_AIR_*, VETAI_MLAIR_*).

MODEL_DIR=./ai_service/models/v2
VETAI_CHAMPION_REGISTRY_PATH=/tmp/vetai-champion-registry
